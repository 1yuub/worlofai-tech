# WorldOfAI Tech — API Key Configuration
# Edit js/config.js with these values (no build step needed)

# ── NEWS API KEYS ──────────────────────────────────────────────────────────────
# Get a free key at https://newsapi.org
# Note: NewsAPI requires domain registration for browser-side requests.
# Register 1yuub.github.io at newsapi.org for production use.
NEWSAPI_KEY=your_newsapi_key_here

# Get a free key at https://cryptopanic.com/developers/api/
CRYPTOPANIC_KEY=your_cryptopanic_key_here

# Get a free key at https://www.coingecko.com/en/api
COINGECKO_KEY=your_coingecko_key_here

# ── GOOGLE ADSENSE ─────────────────────────────────────────────────────────────
# Your AdSense publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
# 1. Sign up at https://adsense.google.com
# 2. After approval, update CONFIG.ADSENSE_PUBLISHER_ID in js/config.js
# 3. Uncomment the AdSense script tag in index.html
# See ADSENSE_GUIDE.md for full setup instructions
ADSENSE_PUBLISHER_ID=ca-pub-YOUR_PUBLISHER_ID

